{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window permissions for TokenScope",
  "windows": ["main"],
  "permissions": [
    "core:app:allow-version",
    "dialog:allow-open",
    "process:allow-restart",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
